# =========================================================================
# TWICE World Tour 360° Fancam Archive - Environment Variables Template
# =========================================================================
# Copy this file to '.env' in both /backend and /frontend directories 
# (or set them in your OS/Deployment environment)

# -------------------------------------------------------------------------
# BACKEND SETTINGS (Put these in /backend/.env)
# -------------------------------------------------------------------------

# Gemini API Key for AI-powered tagging and setlist analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Secret key for admin actions (e.g., approving contributions)
ADMIN_SECRET_KEY=twice360

# Database Connection
# Option A: Local SQLite (Default for development)
# DATABASE_URL=sqlite:///./twice_fancam.db
# Option B: Supabase / PostgreSQL (For production)
# DATABASE_URL=postgresql://postgres.[id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# If true, AI/Community contributions are automatically approved.
# If false, they go to the admin queue.
AUTO_APPROVE=false


# -------------------------------------------------------------------------
# FRONTEND SETTINGS (Put these in /frontend/.env)
# -------------------------------------------------------------------------

# The base URL of your FastAPI backend.
# Local development: http://localhost:8000/api
# Production: https://your-backend-api.vercel.app/api
VITE_API_BASE_URL=http://localhost:8000/api

# -------------------------------------------------------------------------
# CRAWLER SETTINGS (For step2_recommendation.py or ai_contributor_sync.py)
# -------------------------------------------------------------------------

# Point this to your live API if running crawlers remotely
# API_BASE_URL=https://your-backend-api.vercel.app/api
