# API Configuration
# GEMINI_API_KEY=your_api_key_here

# Application Configuration
# If set to true, all contributions (new videos, song tags, etc.) are automatically applied.
# If set to false, they go to the "Pending Reviews" admin queue.
AUTO_APPROVE=false

# Database Settings
# Default is local SQLite: sqlite:///twice_fancam.db
# For production (e.g., Supabase):
# DATABASE_URL=postgresql://postgres.[your-project-id]:[your-password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres